# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# ── Server ───────────────────────────────────────────────────────────────
PORT=4000

# Random secret used to sign login sessions (JWTs). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# ── Ollama (LLM) — behavior translation + photo scan analysis ───────────
# See server/llm.js for full setup notes. Two options:
#
# Option A — local Ollama (install from https://ollama.com, then):
#   ollama pull llama3.2
#   ollama pull llava
#   OLLAMA_BASE_URL=http://localhost:11434
#   OLLAMA_MODEL=llama3.2
#   OLLAMA_VISION_MODEL=llava
#   (leave OLLAMA_API_KEY empty)
#
# Option B — Ollama Cloud (no local GPU needed):
#   Get a key from https://ollama.com/settings/keys
#   OLLAMA_BASE_URL=https://ollama.com
#   OLLAMA_API_KEY=your_api_key_here
#   OLLAMA_MODEL=gpt-oss:120b-cloud
#   OLLAMA_VISION_MODEL=qwen3-vl:235b-cloud
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava

# ── Geoapify (Places API) — nearby vets & shelters ───────────────────────
# Free key, no credit card required: https://myprojects.geoapify.com/
GEOAPIFY_API_KEY=******************
